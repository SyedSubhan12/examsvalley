# ==========================================
# ExamsValley Environment Variables
# ==========================================

# ==========================================
# REQUIRED - Backend API Configuration
# ==========================================
# upriser-web Express backend — ALL /api/* calls go here.
# Tailscale IP of this machine: 100.72.195.67  |  upriser-web port: 5000
# Local emulator only:  http://10.0.2.2:5000  (Android emulator loopback)
# Physical device (Tailscale enrolled): http://100.72.195.67:5000
EXPO_PUBLIC_API_URL=http://100.72.195.67:5000

# Google OAuth — required for mobile Google sign-in
GOOGLE_CLIENT_ID=246078119801-v5gaigde4pute444qmu4aohtdogkc26c.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=246078119801-5td0kkstu4qhapb4hku6ego3jnl8oppn.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=246078119801-5td0kkstu4qhapb4hku6ego3jnl8oppn.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=246078119801-v5gaigde4pute444qmu4aohtdogkc26c.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=246078119801-5td0kkstu4qhapb4hku6ego3jnl8oppn.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=46078119801-5td0kkstu4qhapb4hku6ego3jnl8oppn.apps.googleusercontent.com

# JWT secret — must match JWT_SECRET in upriser-web .env
# JWT_SECRET=generate_with_(node -e "require('crypto').randomBytes(64).toString('hex')")

# Expo Router API route DB connection (same DB as upriser-web)
DATABASE_URL=postgresql://postgres.bjfmrfarfxqngtimiqpx:Uprisertheschool@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ==========================================
# OPTIONAL - Environment Configuration
# ==========================================
# Development environment setting
# Set to 'development' for local development with debugging enabled
# Set to 'production' for production builds with optimizations
NODE_ENV=development

# ==========================================
# OPTIONAL - Expo & EAS Configuration
# ==========================================
# Expo Application Services (EAS) authentication token
# Required only if using `eas build` or `eas submit`
# Generate token at: https://expo.dev/
# EXPO_TOKEN=your_eas_token_here

# Enable Expo debug mode (shows more verbose logging)
# EXPO_DEBUG=false

# ==========================================
# OPTIONAL - Development Server Configuration
# ==========================================
# Custom Expo development server host (if needed)
EXPO_DEVELOPER_TOOL_DISPLAY_LOGS=true

# ==========================================
# API ENDPOINTS REFERENCE (for documentation)
# ==========================================
# The following endpoints are called through EXPO_PUBLIC_API_URL:
# - /api/auth/me - Check current user authentication
# - /api/auth/login - User login
# - /api/auth/logout - User logout
# - /api/auth/check-email - Verify email exists
# - /api/auth/verify-email-otp - Verify OTP for email
# - /api/auth/resend-verification - Resend verification email
# - /api/student/registration - Check student registration status
# - /api/tutor/registration - Check teacher registration status
# - /api/curriculum/boards - Get curriculum boards
# - /api/curriculum/files/upload - Upload curriculum files
# - /api/curriculum/nodes - Get curriculum nodes
# - /api/curriculum/resource-categories - Get resource categories
# - /api/admin/overview - Admin dashboard overview
# - /api/admin/materials - Get materials for moderation
# - /api/admin/materials/{id}/approve - Approve material
# - /api/admin/materials/{id}/reject - Reject material
# - /api/admin/feedback - Get user feedback
# - /api/admin/users - Get all users
# - /api/admin/teachers - Get teachers for management
# - /api/admin/boards - Get curriculum boards for management
# - /api/user/profile - Get user profile
# - /api/subjects - Get subjects
# - /api/announcements - Get announcements
# - /api/topics - Get topics
